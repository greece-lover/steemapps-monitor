# Reporter configuration — copy to `.env.local` on the VM, chmod 600,
# owned by the `steemapps-reporter` system user. NEVER commit the live
# file; `.env.*` is ignored by .gitignore.

# Operating mode. `prod` broadcasts to the Steem chain. `dev` prints the
# rendered post and the `custom_json` payload to stdout and returns.
STEEMAPPS_REPORTER_MODE=dev

# Account that signs the two operations. Phase-5 decision: a dedicated
# `steem-api-health`, not the @greece-lover witness account.
STEEMAPPS_REPORTER_ACCOUNT=steem-api-health

# Posting key (WIF-format) for the reporter account. Required in prod
# mode, ignored in dev mode. Holger sets this manually on the VM after
# first deploy — it is never stored in the repo or in this file.
STEEMAPPS_REPORTER_POSTING_KEY=

# Operation id for the raw-data `custom_json`. Changing this breaks
# downstream consumers (Welako, third-party dashboards) — treat as a
# stable public schema identifier.
STEEMAPPS_REPORTER_CUSTOM_JSON_ID=steemapps_api_stats_daily

# Tags on the comment.
STEEMAPPS_REPORTER_TAGS=steem,api,monitoring,witness,steemapps

# Retry policy for transient broadcast failures (network, RPC).
STEEMAPPS_REPORTER_RETRY=3
STEEMAPPS_REPORTER_RETRY_SLEEP=60

# Overridable links rendered into the post footer.
STEEMAPPS_REPORTER_DASHBOARD_URL=https://api.steemapps.com
STEEMAPPS_REPORTER_REPO_URL=https://github.com/greece-lover/steemapps-monitor
STEEMAPPS_REPORTER_WITNESS_URL=https://steemitwallet.com/~witnesses
STEEMAPPS_REPORTER_METHODOLOGY_URL=https://github.com/greece-lover/steemapps-monitor/blob/main/docs/MEASUREMENT-METHODOLOGY.md
