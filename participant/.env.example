# Copy this file to .env and fill in your values. Never commit .env.
#
# The API key is issued through the self-service form at
# https://api.steemapps.com/join.html — once retrieved it cannot be
# fetched a second time. Keep it on the host running this script and
# nowhere else.

# Required.
STEEMAPPS_API_KEY=sapk_paste_your_key_here

# Optional — defaults shown.
STEEMAPPS_API_BASE=https://api.steemapps.com

# Local label used in log output only. The label shown on the Sources
# page was set during registration at https://api.steemapps.com/join.html.
# Changing this here does NOT update the dashboard.
STEEMAPPS_LABEL=my-server

STEEMAPPS_POLL_INTERVAL_S=60
STEEMAPPS_FLUSH_INTERVAL_S=300
STEEMAPPS_TIMEOUT_S=8.0
